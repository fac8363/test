        // --- STAR MATH ---
        function getEarnedStars(node) {
            if(!node || !node.skills) return 0;
            return node.skills.reduce((sum, s) => {
                const key = node.id + "_" + s.name + "_rating";
                return sum + (state[key] || 0);
            }, 0);
        }

        function isNodePassed(node) {
            if(!node || !node.skills) return true;
            const earned = getEarnedStars(node);
            const req = node.passReq || (node.skills.length * 5);
            return earned >= req;
        }

