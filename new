        function updateTransform(smooth = false) {
            const forest = document.getElementById('forest-container');
            forest.style.transition = smooth ? 'transform 0.4s cubic-bezier(0.25, 1, 0.5, 1)' : 'none';
            forest.style.transform = `translateX(${panX}px) translateY(${panY}px) scale(${currentZoom})`;
        }

        function changeZoom(amount) {
            currentZoom += amount;
            if (currentZoom < 0.2) currentZoom = 0.2;
            if (currentZoom > 2) currentZoom = 2;
            updateTransform(true);
        }

        function centerCamera() {
            panY = 0; currentZoom = 1.0; 
            centerOnPillar(activeIndex, true);
        }
        
        function resetCamera() {
            panY = 0; currentZoom = 1.0; activeIndex = 0;
            render();
            setTimeout(() => { centerOnPillar(0, false); }, 50);
        }

        function centerOnPillar(index, smooth = true) {
            const pillars = document.querySelectorAll('.parallel-col');
            if (!pillars[index]) return;
            activeIndex = index;

            pillars.forEach((p, i) => {
                const isActive = i === activeIndex;
                p.classList.toggle('active-pillar', isActive);
                p.classList.toggle('inactive-pillar', !isActive);
                if(p.dataset.lastActiveState !== String(isActive)) {
                    p.dataset.lastActiveState = String(isActive);
                    recalculateFogForPillar(p);
                }
            });

            void document.body.offsetHeight;
            
            const targetPillar = pillars[activeIndex];
            // Fix: Shift the absolute origin by the exact center of the pillar
            panX = -(targetPillar.offsetLeft + targetPillar.offsetWidth / 2);
            updateTransform(smooth);
            
            document.getElementById('navLeft').style.display = activeIndex === 0 ? 'none' : 'flex';
            document.getElementById('navRight').style.display = activeIndex === pillars.length - 1 ? 'none' : 'flex';
        }

        function slideCarousel(direction) {
            const pillars = document.querySelectorAll('.parallel-col');
            let targetIdx = activeIndex + direction;
            if (targetIdx >= 0 && targetIdx < pillars.length && targetIdx !== activeIndex) {
                centerOnPillar(targetIdx, true);
            }
        }

        // --- MENU LOGIC ---
        function startJourney() {
            currentProjectKey = document.getElementById('mainMenuSelect').value;
            document.getElementById('appMenuSelect').value = currentProjectKey;
            
            document.getElementById('landingMenu').classList.add('hidden');
            const app = document.getElementById('appContainer');
            app.style.display = 'flex';
            setTimeout(() => {
                app.classList.add('visible');
                resetCamera(); 
            }, 50);
        }

        function switchProjectFromApp() {
            currentProjectKey = document.getElementById('appMenuSelect').value;
            document.getElementById('mainMenuSelect').value = currentProjectKey;
            resetCamera();
        }

        function returnToMenu() {
            document.getElementById('appContainer').classList.remove('visible');
            setTimeout(() => {
                document.getElementById('appContainer').style.display = 'none';
                document.getElementById('landingMenu').classList.remove('hidden');
            }, 400); 
        }

        function openFAQ() { document.getElementById('faqModal').style.display = 'flex'; }

        // --- RATINGS ---
        function attemptToggle(key, event) {
            pendingTask = { type: 'checkbox', key: key };
            openRatingModal(event);
        }

        function openRatingModal(event) {
            document.querySelectorAll('input[name="rating"]').forEach(r => r.checked = false);
            const color = projectLibrary[currentProjectKey].colors.left;
            document.getElementById('ratingTitle').style.color = color;
            
            const modal = document.getElementById('ratingModal');
            const popup = modal.querySelector('.modal-content');
            popup.style.borderColor = color;
            modal.style.display = 'block'; 

            const rect = event.currentTarget.getBoundingClientRect();
            popup.style.top = `${rect.top - 185}px`;
            popup.style.left = `${rect.left + rect.width / 2 - 145}px`;
        }

        function submitRating(stars) {
            state[pendingTask.key + "_rating"] = stars;
            state[pendingTask.key] = true; 
            pendingTask = null; 
            closeModal('ratingModal');
            save(); 
        }

        function clearRating() {
            state[pendingTask.key] = false;
            delete state[pendingTask.key + "_rating"];
            pendingTask = null;
            closeModal('ratingModal');
            save();
        }

        function cancelRating(event) {
            if (event && event.target.id !== 'ratingModal') return;
            pendingTask = null;
            closeModal('ratingModal');
            render(); 
        }

        function openGuide(title, htmlContent) {
            document.getElementById('modalTitle').innerText = title;
            document.getElementById('modalBody').innerHTML = htmlContent;
            document.getElementById('modalTitle').style.color = projectLibrary[currentProjectKey].colors.left;
            document.querySelector('#guideModal .modal-content').style.borderTopColor = projectLibrary[currentProjectKey].colors.left;
            document.getElementById('guideModal').style.display = 'flex';
        }

        function closeModal(modalId, event) {
            if (event && event.target.id !== modalId) return;
            document.getElementById(modalId).style.display = 'none';
        }

        // --- RENDER ENGINE ---
        function render() {
            const project = projectLibrary[currentProjectKey];
            const container = document.getElementById('forest-container');
            container.innerHTML = ''; 
            document.documentElement.style.setProperty('--theme-left', project.colors.left);
            
            const pRow = document.createElement('div');
            pRow.className = 'parallel-row';

            if (project.leftTree) renderTreeColumn(pRow, project.leftTree, 'theme-left');
            if (project.rightTree) renderTreeColumn(pRow, project.rightTree, 'theme-right');
            
            container.appendChild(pRow);
            centerOnPillar(activeIndex, false); 
        }

        function renderTreeColumn(container, treeData, theme) {
            if (treeData.tier1.layout === 'parallel') {
                treeData.tier1.paths.forEach((pathData) => {
                    const col = document.createElement('div');
                    col.className = 'parallel-col inactive-pillar';
                    let frontlineDist = 0; 

                    const rootWrapper = document.createElement('div');
                    rootWrapper.className = 'root-node-wrapper';
                    rootWrapper.addEventListener('click', () => {
                        const pillars = Array.from(document.querySelectorAll('.parallel-col'));
                        const idx = pillars.indexOf(col);
                        if(idx !== activeIndex) centerOnPillar(idx, true);
                    });

                    const upperWrapper = document.createElement('div');
                    upperWrapper.className = 'upper-branches';

                    pathData.nodes.forEach((node, nodeIdx) => {
                        const isPassed = isNodePassed(node);
                        let myDist = isPassed ? -1 : frontlineDist;
                        if (!isPassed) frontlineDist++;

                        const parentNode = nodeIdx > 0 ? pathData.nodes[nodeIdx - 1] : null;
                        const card = createCard(node, pathData.theme || theme, myDist, parentNode);
                        
                        if (nodeIdx === 0) rootWrapper.appendChild(card);
                        else { card.classList.add('stacked-node'); upperWrapper.appendChild(card); }
                    });
                    
                    if (pathData.branches) {
                        const parentNode = pathData.nodes[pathData.nodes.length - 1]; 
                        const branchTree = renderBranchesRecursively(pathData.branches, pathData.theme || theme, frontlineDist, parentNode);
                        upperWrapper.appendChild(branchTree);
                    }
                    
                    col.appendChild(rootWrapper);
                    col.appendChild(upperWrapper);
                    container.appendChild(col);
                });
            } 
            else if (treeData.tier1.layout === 'converge') {
                const col = document.createElement('div');
                col.className = 'parallel-col inactive-pillar';
                
                let frontlineDist = 0;
                const rootsComplete = treeData.tier1.roots.every(r => isNodePassed(r));

                const rootWrapper = document.createElement('div');
                rootWrapper.className = 'root-node-wrapper foundation-row';
                rootWrapper.addEventListener('click', () => {
                    const pillars = Array.from(document.querySelectorAll('.parallel-col'));
                    const idx = pillars.indexOf(col);
                    if(idx !== activeIndex) centerOnPillar(idx, true);
                });
                
                treeData.tier1.roots.forEach(node => { 
                    let myDist = isNodePassed(node) ? -1 : 0;
                    rootWrapper.appendChild(createCard(node, theme, myDist, null)); 
                });

                if (!rootsComplete) frontlineDist++;

                const upperWrapper = document.createElement('div');
                upperWrapper.className = 'upper-branches';

                const middleNode = treeData.tier1.middle;
                const middleComplete = isNodePassed(middleNode);
                let midDist = middleComplete ? -1 : frontlineDist;
                if (!middleComplete) frontlineDist++;

                const midCard = createCard(middleNode, theme, midDist, treeData.tier1.roots[0]);
                midCard.classList.add('stacked-node');
                upperWrapper.appendChild(midCard);

                const bossNode = treeData.tier1.boss;
                const bossComplete = isNodePassed(bossNode);
                let bossDist = bossComplete ? -1 : frontlineDist;
                if (!bossComplete) frontlineDist++;

                const bossCard = createCard(bossNode, theme, bossDist, middleNode);
                bossCard.classList.add('stacked-node');
                upperWrapper.appendChild(bossCard);
                
                if (treeData.tier2) {
                    const branchTree = renderBranchesRecursively(treeData.tier2.branches, theme, frontlineDist, bossNode);
                    upperWrapper.appendChild(branchTree);
                }
                
                col.appendChild(rootWrapper);
                col.appendChild(upperWrapper);
                container.appendChild(col);
            }
        }

        function renderBranchesRecursively(branches, theme, frontlineDist, parentNode) {
            const row = document.createElement('div');
            row.className = `branch-row ${theme}`;
            
            branches.forEach(b => {
                const col = document.createElement('div');
                col.className = `branch-col`;
                
                let currentDist = frontlineDist;
                const nodesToRender = b.nodes || [b];
                
                nodesToRender.forEach((node, idx) => {
                    const isPassed = isNodePassed(node);
                    let myDist = isPassed ? -1 : currentDist;
                    if (!isPassed) currentDist++;
                    
                    const myParent = idx > 0 ? nodesToRender[idx - 1] : parentNode;
                    const card = createCard(node, b.theme || theme, myDist, myParent);
                    if (idx > 0) card.classList.add('stacked-node');
                    col.appendChild(card);
                });
                
                if (b.branches || b.subBranches) {
                    const nextBranches = b.branches || b.subBranches;
                    const myLastNode = nodesToRender[nodesToRender.length - 1];
                    const subRow = renderBranchesRecursively(nextBranches, b.theme || theme, currentDist, myLastNode);
                    col.appendChild(subRow);
                }
                row.appendChild(col);
            });
            return row;
        }

        function createCard(node, theme, dist, parentNode) {
            const cardTheme = node.theme || theme; 
            const isGatewayOrBoss = node.isBoss || node.isGateway;
            
            let distClass = '';
            if (dist === -1) distClass = 'dist-completed';
            else if (dist === 0) distClass = 'dist-playable';
            else if (dist === 1) distClass = 'dist-locked-1';
            else if (dist === 2) distClass = 'dist-locked-2';
            else if (dist >= 3) distClass = 'dist-locked-3';
            
            const div = document.createElement('div');
            div.className = `node-card ${cardTheme} ${isGatewayOrBoss ? 'gateway-card' : ''} ${distClass}`;
            
            if (isGatewayOrBoss && dist === -1) div.classList.add('unlocked-boss');

            let badgeHtml = '';
            if (dist === 1 && parentNode) {
                const earned = getEarnedStars(parentNode);
                const req = parentNode.passReq || ((parentNode.skills || []).length * 5);
                badgeHtml = `<div class="lock-badge">🔒 ${earned} / ${req} ⭐</div>`;
            }

            const skills = node.skills || [];
            const skillsHtml = skills.map(s => {
                const key = node.id + "_" + s.name;
                const val = state[key] || 0;
                const ratingVal = state[key + "_rating"]; 

                const checked = (val === true) ? 'checked' : '';
                const control = `<input type="checkbox" ${checked} onchange="attemptToggle('${key}', event)">`;

                let guideHtml = '';
                if (s.instructions) {
                    const safeHTML = s.instructions.replace(/"/g, '&quot;').replace(/'/g, "\\'").replace(/(\r\n|\n|\r)/gm, "");
                    guideHtml = `<span class="guide-icon" onclick="openGuide('${s.name}', '${safeHTML}')">📖</span>`;
                }
                
                let starsStr = '';
                if (ratingVal) {
                    for (let i = 1; i <= 5; i++) {
                        starsStr += `<span class="star-${(i <= ratingVal) ? 'filled' : 'empty'}">★</span>`;
                    }
                }

                return `
                    <div class="skill-group">
                        <div class="skill-header">
                            <div class="skill-name-wrapper"><span class="skill-name">${s.name}</span>${guideHtml}</div>
                            ${control}
                        </div>
                        <div class="task-rating-display">${starsStr}</div>
                        <span class="skill-desc">${s.desc}</span>
                    </div>
                `;
            }).join('');

            div.innerHTML = `${badgeHtml}<div class="title">${node.title}</div>${skillsHtml}`;
            return div;
        }

        function recalculateFogForPillar(pillarCol) {
            const isActive = pillarCol.classList.contains('active-pillar');
            let frontlineDist = 0; 

            const rootCard = pillarCol.querySelector('.root-node-wrapper > .node-card');
            if(rootCard) {
                 if(!rootCard.classList.contains('dist-completed')) {
                     applyFogToCard(rootCard, 0, isActive);
                     frontlineDist = 1;
                 }
            }

            pillarCol.querySelectorAll('.upper-branches .node-card, .branch-row .node-card').forEach(card => {
                if(!card.classList.contains('dist-completed')) {
                    applyFogToCard(card, frontlineDist, isActive);
                    if(!card.closest('.branch-row')) frontlineDist++;
                }
            });
        }

        function applyFogToCard(card, dist, isActive) {
            const finalDist = isActive ? dist : (dist + 3); 
            card.classList.toggle('dist-playable', finalDist === 0);
            card.classList.toggle('dist-locked-1', finalDist === 1);
            card.classList.toggle('dist-locked-2', finalDist === 2);
            card.classList.toggle('dist-locked-3', finalDist >= 3);
        }

        // --- INFINITE CANVAS DRAG & DROP ENGINE ---
        const viewport = document.getElementById('viewport');
        let isDragging = false, dragStartX, dragStartY, initialPanY;

        viewport.addEventListener('mousedown', (e) => {
            if(e.target.closest('.node-card') || e.target.closest('.modal-content') || e.target.closest('.floating-controls') || e.target.closest('.nav-arrow') || e.target.closest('.app-header')) return;
            isDragging = true; dragStartX = e.clientX; dragStartY = e.clientY; initialPanY = panY;
            viewport.style.cursor = 'grabbing'; closeModal('ratingModal');
        });

        window.addEventListener('mousemove', (e) => { 
            if (!isDragging) return; e.preventDefault();
            panY = initialPanY + (e.clientY - dragStartY);
            if (panY < 0) panY = 0; 
            updateTransform(false); 
        });

        window.addEventListener('mouseup', (e) => { 
            if (!isDragging) return;
            isDragging = false; viewport.style.cursor = 'grab'; 
            let deltaX = e.clientX - dragStartX;
            if (deltaX > 50) slideCarousel(-1);
            else if (deltaX < -50) slideCarousel(1);
            else updateTransform(true);
        });

        let touchStartX, touchStartY, touchInitialPanY;
        viewport.addEventListener('touchstart', (e) => {
            if(e.target.closest('.node-card') || e.target.closest('.modal-content') || e.target.closest('.floating-controls') || e.target.closest('.nav-arrow') || e.target.closest('.app-header')) return;
            if(e.touches.length === 1) {
                isDragging = true; closeModal('ratingModal');
                touchStartX = e.touches[0].clientX; touchStartY = e.touches[0].clientY; touchInitialPanY = panY;
            }
        }, {passive: false});

        window.addEventListener('touchmove', (e) => { 
            if (isDragging && e.touches.length === 1) { 
                e.preventDefault(); 
                panY = touchInitialPanY + (e.touches[0].clientY - touchStartY);
                if (panY < 0) panY = 0; updateTransform(false); 
            } 
        }, {passive: false});

        window.addEventListener('touchend', (e) => { 
            if (!isDragging) return;
            isDragging = false;
            let deltaX = e.changedTouches[0].clientX - touchStartX;
            if (deltaX > 50) slideCarousel(-1);
            else if (deltaX < -50) slideCarousel(1);
            else updateTransform(true);
        });

        // Initial Boot
        resetCamera();

    </script>
</body>
</html>
