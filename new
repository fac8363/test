<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <meta name="theme-color" content="#fdf8e4">
    <title>Branch Out - Skill Trees</title>
    
    <script>
        if (localStorage.getItem('branchOutTheme') === 'dark') {
            document.documentElement.setAttribute('data-theme', 'dark');
            document.querySelector('meta[name="theme-color"]').setAttribute('content', '#111111');
        }
    </script>

    <style>
        :root {
            /* --- LIGHT THEME (DEFAULT) --- */
            --bg: #fdf8e4;           
            --card-bg: #ffffff;      
            --text: #2c3e50;         
            --subtext: #7f8c8d;      
            --dot-color: rgba(0, 0, 0, 0.05);
            --modal-bg: rgba(255, 255, 255, 0.8);
            --header-bg: rgba(253, 248, 228, 0.85);
            --btn-bg: rgba(255, 255, 255, 0.9);
            --border-color: #eeeeee;
            
            --theme-left: #ff7043; 
            --theme-right: #f06292;
            --unlocked-accent: #00e676;
            --star-gold: #f1c40f;
        }

        [data-theme="dark"] {
            /* --- DARK THEME OVERRIDES --- */
            --bg: #111111;
            --card-bg: #1a1a1a;
            --text: #eeeeee;
            --subtext: #888888;
            --dot-color: rgba(255, 255, 255, 0.05);
            --modal-bg: rgba(17, 17, 17, 0.8);
            --header-bg: rgba(17, 17, 17, 0.9);
            --btn-bg: rgba(0, 0, 0, 0.8);
            --border-color: #333333;
        }

        html, body {
            margin: 0; padding: 0; width: 100vw; height: 100dvh; 
            overflow: hidden; background-color: var(--bg); color: var(--text);
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
            background-image: radial-gradient(var(--dot-color) 1px, transparent 1px);
            background-size: 20px 20px; transition: background-color 0.3s, color 0.3s;
        }

        /* --- LANDING MENU --- */
        .landing-menu {
            position: fixed; inset: 0; z-index: 5000; display: flex; flex-direction: column; justify-content: center; align-items: center;
            background-color: var(--bg); background-image: radial-gradient(var(--dot-color) 1px, transparent 1px);
            background-size: 20px 20px; transition: opacity 0.4s ease, visibility 0.4s, background-color 0.3s;
        }
        .landing-menu.hidden { opacity: 0; visibility: hidden; pointer-events: none; }
        .app-title-main { font-size: 3.5rem; font-weight: 900; color: var(--text); margin: 0 0 10px 0; letter-spacing: -1px; text-align: center; transition: color 0.3s;}
        .app-tagline { font-size: 1.1rem; color: var(--subtext); margin: 0 0 40px 0; font-style: italic; text-align: center; transition: color 0.3s;}
        
        .menu-card {
            background: var(--modal-bg); backdrop-filter: blur(10px); padding: 30px; border-radius: 16px; border: 1px solid var(--border-color);
            box-shadow: 0 10px 30px rgba(0,0,0,0.1); display: flex; flex-direction: column; gap: 20px; width: 90%; max-width: 320px; transition: background 0.3s, border-color 0.3s;
        }
        .menu-select {
            background: var(--card-bg); color: var(--text); font-size: 1.1rem; padding: 12px 15px; border: 2px solid var(--border-color); border-radius: 8px; 
            cursor: pointer; outline: none; font-weight: bold; width: 100%; transition: background 0.3s, color 0.3s, border-color 0.3s;
        }
        .btn-start {
            background: var(--text); color: var(--bg); border: none; padding: 15px; border-radius: 8px; font-size: 1.2rem; font-weight: bold; cursor: pointer;
            transition: transform 0.1s, background 0.3s, color 0.3s; text-transform: uppercase; letter-spacing: 1px;
        }
        .btn-start:active { transform: scale(0.98); opacity: 0.8; }
        .btn-faq { background: transparent; color: var(--subtext); border: none; padding: 10px; font-size: 0.9rem; cursor: pointer; text-decoration: underline; margin-top: 10px; transition: color 0.2s; }
        .btn-faq:hover { color: var(--text); }

        /* --- APP CONTAINER --- */
        .app-container {
            display: flex; flex-direction: column; width: 100%; height: 100%; opacity: 0; visibility: hidden; transition: opacity 0.4s ease 0.2s;
        }
        .app-container.visible { opacity: 1; visibility: visible; }

        /* --- HEADER --- */
        .app-header {
            background: var(--header-bg); backdrop-filter: blur(12px); padding: 15px 20px; z-index: 100;
            border-bottom: 1px solid var(--border-color); box-shadow: 0 4px 15px rgba(0,0,0,0.05); flex-shrink: 0;
            display: flex; justify-content: space-between; align-items: center; transition: background 0.3s, border-color 0.3s;
        }
        .header-select {
            background: transparent; border: none; font-size: 1.2rem; font-weight: 800; text-transform: uppercase; color: var(--text); letter-spacing: 1px; 
            cursor: pointer; outline: none; text-align: center; transition: color 0.3s; max-width: 60vw; text-overflow: ellipsis;
        }
        .header-select:hover { color: var(--theme-left); }
        .btn-back { background: var(--card-bg); border: 1px solid var(--border-color); padding: 6px 12px; border-radius: 6px; font-weight: bold; color: var(--text); cursor: pointer; transition: background 0.3s, color 0.3s, border-color 0.3s;}
        .btn-back:active { transform: scale(0.95); }

        /* --- THE VIEWPORT --- */
        .tree-viewport { flex: 1; width: 100%; position: relative; overflow: hidden; cursor: grab; }
        .tree-viewport:active { cursor: grabbing; }

        /* --- ABSOLUTE PAN ENGINE --- */
        .forest {
            display: flex; gap: 80px; align-items: flex-end; justify-content: flex-start;
            position: absolute; bottom: 50px; left: 50vw; width: max-content; transform-origin: bottom left; 
        }

        .parallel-row { display: flex; gap: 60px; align-items: flex-end; position: relative; width: max-content; }
        .parallel-col { position: relative; display: flex; flex-direction: column-reverse; align-items: center; z-index: 1; transition: z-index 0s; }
        .parallel-col.active-pillar { z-index: 50; }

        /* --- BLOOM ENGINE --- */
        .root-node-wrapper { position: relative; z-index: 20; transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1); }
        .inactive-pillar .root-node-wrapper { opacity: 0.5; transform: scale(0.9); cursor: pointer; filter: grayscale(100%); }
        .inactive-pillar .root-node-wrapper:hover { opacity: 0.8; transform: scale(0.95); }
        .active-pillar .root-node-wrapper { opacity: 1; transform: scale(1); filter: grayscale(0%); }

        .upper-branches {
            position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%); display: flex; flex-direction: column-reverse; align-items: center;
            padding-bottom: 30px; z-index: 10; opacity: 0; visibility: hidden; pointer-events: none; margin-bottom: -30px; transition: all 0.4s cubic-bezier(0.25, 1, 0.5, 1);
        }
        .active-pillar .upper-branches { opacity: 1; visibility: visible; pointer-events: auto; margin-bottom: 0; }

        /* --- BRANCHING (No lines) --- */
        .branch-row { display: flex; gap: 30px; position: relative; margin-bottom: 30px; justify-content: center; }
        .branch-col { position: relative; display: flex; flex-direction: column-reverse; align-items: center; gap: 30px; }
        .foundation-row { display: flex; gap: 30px; position: relative; justify-content: center; }

        /* --- CARDS & BADGES --- */
        .node-card {
            background: var(--card-bg); width: 240px; padding: 15px; border-radius: 12px; border: 2px solid var(--border-color); position: relative; z-index: 2; 
            transition: transform 0.2s ease, opacity 0.5s ease, filter 0.5s ease, background 0.3s, border-color 0.3s; cursor: default; flex-shrink: 0; margin: 0; box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .node-card:active { transform: scale(0.98); }
        .boss-card, .gateway-card { border-width: 3px !important; }
        .stacked-node { margin-bottom: 30px; }

        .lock-badge {
            position: absolute; top: -15px; left: 50%; transform: translateX(-50%); background: var(--card-bg); color: var(--text); padding: 4px 12px; border-radius: 20px; font-weight: bold; font-size: 0.8rem; border: 2px solid var(--border-color); box-shadow: 0 4px 10px rgba(0,0,0,0.1); z-index: 10; white-space: nowrap; transition: background 0.3s, color 0.3s, border-color 0.3s; display: flex; align-items: center; gap: 4px;
        }
        [data-theme="dark"] .lock-badge { box-shadow: 0 4px 10px rgba(0,0,0,0.5); }

        .theme-easy { border-color: #00e676; }
        .theme-easy .title { color: #00e676; }
        .theme-med { border-color: #ffb300; }
        .theme-med .title { color: #ffb300; }
        .theme-hard { border-color: #ff5252; }
        .theme-hard .title { color: #ff5252; }
        .title { font-weight: bold; text-transform: uppercase; font-size: 0.9rem; margin-bottom: 15px; text-align: center; }

        /* --- FOG OF WAR --- */
        .dist-locked-1 { opacity: 0.5; filter: grayscale(100%); }
        .dist-locked-2 { opacity: 0.15; filter: blur(3px) grayscale(100%); }
        .dist-locked-3 { opacity: 0; pointer-events: none; }
        .dist-locked-1 input, .dist-locked-1 .counter-btn, .dist-locked-2 input, .dist-locked-2 .counter-btn { pointer-events: none; opacity: 0.4; }

        /* --- BOSS PULSING --- */
        .unlocked-boss.theme-easy { animation: pulse-easy 2s infinite; }
        .unlocked-boss.theme-med { animation: pulse-med 2s infinite; }
        .unlocked-boss.theme-hard { animation: pulse-hard 2s infinite; }
        @keyframes pulse-easy { 0% { box-shadow: 0 4px 0 #00b25c, 0 0 5px rgba(0,230,118,0.2); } 50% { box-shadow: 0 4px 0 #00b25c, 0 0 25px rgba(0,230,118,0.6); } 100% { box-shadow: 0 4px 0 #00b25c, 0 0 5px rgba(0,230,118,0.2); } }
        @keyframes pulse-med { 0% { box-shadow: 0 4px 0 #e6a100, 0 0 5px rgba(255,179,0,0.2); } 50% { box-shadow: 0 4px 0 #e6a100, 0 0 25px rgba(255,179,0,0.6); } 100% { box-shadow: 0 4px 0 #e6a100, 0 0 5px rgba(255,179,0,0.2); } }
        @keyframes pulse-hard { 0% { box-shadow: 0 4px 0 #e04444, 0 0 5px rgba(255,82,82,0.2); } 50% { box-shadow: 0 4px 0 #e04444, 0 0 25px rgba(255,82,82,0.6); } 100% { box-shadow: 0 4px 0 #e04444, 0 0 5px rgba(255,82,82,0.2); } }

        /* --- INPUTS & ICONS --- */
        .skill-group { margin-bottom: 12px; border-bottom: 1px solid var(--border-color); padding-bottom: 8px; transition: border-color 0.3s; }
        .skill-group:last-child { border-bottom: none; }
        .skill-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
        .skill-name-wrapper { display: flex; align-items: center; gap: 8px; }
        .skill-name { font-weight: bold; color: var(--text); font-size: 0.85rem; transition: color 0.3s;}
        .guide-icon { cursor: pointer; font-size: 1.1rem; filter: grayscale(100%); padding: 5px; margin: -5px; transition: all 0.2s; }
        .guide-icon:active { transform: scale(1.2); filter: grayscale(0%); }
        .task-rating-display { font-size: 0.75rem; margin-top: -2px; margin-bottom: 4px; letter-spacing: 1px; }
        .star-filled { color: var(--star-gold); text-shadow: 0 0 5px rgba(255, 215, 0, 0.4); }
        .star-empty { color: var(--subtext); opacity: 0.5;}
        .skill-desc { font-size: 0.7rem; color: var(--subtext); line-height: 1.3; font-style: italic; display: block; padding-left: 2px; transition: color 0.3s;}
        .skill-header input { accent-color: var(--unlocked-accent); cursor: pointer; width: 20px; height: 20px; }

        /* --- FLOATING CONTROLS --- */
        .floating-controls { position: fixed; bottom: 20px; left: 20px; display: flex; flex-direction: column; gap: 10px; z-index: 100; }
        .btn-ui {
            background: var(--btn-bg); color: var(--subtext); border: 2px solid var(--border-color); border-radius: 50%; 
            width: 45px; height: 45px; display: flex; justify-content: center; align-items: center; cursor: pointer; font-size: 1.5rem; backdrop-filter: blur(5px); font-weight: bold; transition: all 0.3s;
        }
        .btn-ui:active { transform: scale(0.9); color: var(--text); border-color: var(--theme-left); }
        .reset-btn-container { position: fixed; bottom: 20px; right: 20px; z-index: 100; }

        .nav-arrow {
            position: absolute; top: 50%; transform: translateY(-50%); background: var(--btn-bg); color: var(--subtext); border: 2px solid var(--border-color); 
            width: 50px; height: 50px; display: flex; justify-content: center; align-items: center; border-radius: 50%; font-size: 1.5rem; font-weight: bold; cursor: pointer;
            z-index: 100; box-shadow: 0 4px 15px rgba(0,0,0,0.1); backdrop-filter: blur(5px); transition: all 0.3s;
        }
        .nav-arrow:active { transform: translateY(-50%) scale(0.9); color: var(--text); border-color: var(--theme-left);}
        .nav-arrow.left { left: 20px; }
        .nav-arrow.right { right: 20px; }

        /* --- MODALS --- */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); z-index: 1000; justify-content: center; align-items: flex-end; backdrop-filter: blur(5px); }
        .modal-content {
            background: var(--card-bg); border-top: 4px solid var(--theme-left); border-radius: 20px 20px 0 0; padding: 30px; width: 100%; max-height: 80vh; overflow-y: auto; color: var(--text);
            box-shadow: 0 -10px 30px rgba(0,0,0,0.2); position: relative; animation: slideUp 0.3s ease-out; transition: background 0.3s, color 0.3s;
        }
        @keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }
        .modal-title { font-size: 1.4rem; margin-top: 0; border-bottom: 1px solid var(--border-color); padding-bottom: 10px; text-transform: uppercase;}
        .modal-body { line-height: 1.6; font-size: 0.95rem; color: var(--text); padding-bottom: 20px;}
        .close-btn { position: absolute; top: 15px; right: 20px; font-size: 2rem; cursor: pointer; color: var(--subtext); }

        #ratingModal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: transparent; z-index: 2000; }
        #ratingModal .modal-content {
            position: fixed; background: var(--card-bg); border: 2px solid var(--theme-left); border-radius: 12px; padding: 15px 20px; width: 250px; color: var(--text);
            box-shadow: 0 10px 30px rgba(0,0,0,0.2); animation: popIn 0.2s ease-out;
        }
        @keyframes popIn { from { opacity: 0; transform: scale(0.9) translateY(10px); } to { opacity: 1; transform: scale(1) translateY(0); } }
        .star-rating { display: flex; flex-direction: row-reverse; justify-content: center; gap: 8px; margin-top: 10px; }
        .star-rating input { display: none; }
        .star-rating label { font-size: 2.5rem; color: var(--subtext); opacity: 0.3; cursor: pointer; transition: 0.2s ease; }
        .star-rating label:hover, .star-rating label:hover ~ label { color: var(--star-gold); opacity: 1; text-shadow: 0 0 15px rgba(255, 215, 0, 0.5); transform: scale(1.1); }
        .rating-prompt { text-align: center; margin-bottom: 5px; font-size: 0.9rem; color: var(--subtext);}
        .clear-rating-btn { display: block; text-align: center; margin-top: 15px; color: var(--subtext); font-size: 0.8rem; text-decoration: underline; cursor: pointer; transition: color 0.2s; }
        .clear-rating-btn:hover { color: var(--theme-hard); }

    </style>
</head>
<body>

    <div id="landingMenu" class="landing-menu">
        <h1 class="app-title-main">🌿 Branch Out</h1>
        <p class="app-tagline">Choose your path to mastery.</p>
        
        <div class="menu-card">
            <select id="mainMenuSelect" class="menu-select">
                <option value="kitchen">🔪 Kitchen RPG</option>
                <option value="crochet">🧶 Yarn Mastery</option>
                <option value="cocktails">🍸 Mixology</option>
                <option value="mechanics">🔧 Auto Repair</option>
                <option value="running">🏃 Couch to 5K</option>
                <option value="photography">📷 Photography</option>
                <option value="calligraphy">🖋️ Calligraphy</option>
            </select>
            <button class="btn-start" onclick="startJourney()">Begin Journey</button>
        </div>
        <button class="btn-faq" onclick="openFAQ()">What is Branch Out?</button>
    </div>

    <div id="appContainer" class="app-container">
        <div class="app-header">
            <button class="btn-back" onclick="returnToMenu()">⬅ Menu</button>
            <select id="appMenuSelect" class="header-select" onchange="switchProjectFromApp()">
                <option value="kitchen">🔪 Kitchen RPG</option>
                <option value="crochet">🧶 Yarn Mastery</option>
                <option value="cocktails">🍸 Mixology</option>
                <option value="mechanics">🔧 Auto Repair</option>
                <option value="running">🏃 Couch to 5K</option>
                <option value="photography">📷 Photography</option>
                <option value="calligraphy">🖋️ Calligraphy</option>
            </select>
            <div style="width: 70px;"></div> 
        </div>

        <div class="tree-viewport" id="viewport">
            <div id="navLeft" class="nav-arrow left" onclick="slideCarousel(-1)" style="display:none;">❮</div>
            <div id="navRight" class="nav-arrow right" onclick="slideCarousel(1)" style="display:none;">❯</div>

            <div class="forest" id="forest-container"></div>
        </div>

        <div class="floating-controls">
            <button class="btn-ui" onclick="changeZoom(0.15)" title="Zoom In">+</button>
            <button class="btn-ui" onclick="changeZoom(-0.15)" title="Zoom Out">−</button>
            <button class="btn-ui" onclick="centerCamera()" title="Recenter View" style="font-size: 1.1rem;">🎯</button>
            <button class="btn-ui" id="themeToggleBtn" onclick="toggleTheme()" title="Toggle Theme" style="font-size: 1.1rem;">🌙</button>
        </div>
        <div class="reset-btn-container">
            <button class="btn-ui" onclick="resetData()" title="Reset Progress" style="font-size: 1.2rem;">↻</button>
        </div>
    </div>

    <div class="modal-overlay" id="faqModal" onclick="closeModal('faqModal', event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <span class="close-btn" onclick="closeModal('faqModal')">&times;</span>
            <h2 class="modal-title">Welcome to Branch Out</h2>
            <div class="modal-body">
                <strong>What is this?</strong><br>
                Branch Out is a real-life skill tree. It breaks down complex hobbies into a visual map of interconnected skills, just like a video game.<br><br>
                <strong>How to Play:</strong>
                <ol>
                    <li><strong>Learn:</strong> Click the book icon (📖) next to a skill for a quick tutorial.</li>
                    <li><strong>Practice:</strong> Complete the physical task in the real world.</li>
                    <li><strong>Rate & Grind:</strong> Check the box and rate your execution from 1 to 5 stars. If you score low, you can click the task again to re-rate it once you improve!</li>
                    <li><strong>Level Up:</strong> The path ahead is hidden by the "Fog of War". You must earn enough total stars on a tier to unlock the door to the next level!</li>
                </ol>
                <strong>Navigation:</strong><br>
                Click and drag anywhere on the background to pan around the skill map. You can also use the Left and Right arrows (or swipe) to quickly jump between the skill trees. The tree closest to the center expands, while the others step aside.
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="guideModal" onclick="closeModal('guideModal', event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <span class="close-btn" onclick="closeModal('guideModal')">&times;</span>
            <h2 class="modal-title" id="modalTitle">Skill Guide</h2>
            <div class="modal-body" id="modalBody"></div>
        </div>
    </div>

    <div class="modal-overlay" id="ratingModal" onclick="cancelRating(event)">
        <div class="modal-content" onclick="event.stopPropagation()">
            <h2 id="ratingTitle" style="text-align: center; margin: 0 0 5px 0; font-size: 1.1rem; border:none; text-transform: uppercase;">Task Complete!</h2>
            <p class="rating-prompt">Rate your execution:</p>
            <div class="star-rating">
                <input type="radio" id="star5" name="rating" value="5" onclick="submitRating(5)"><label for="star5" title="Flawless">★</label>
                <input type="radio" id="star4" name="rating" value="4" onclick="submitRating(4)"><label for="star4" title="Great">★</label>
                <input type="radio" id="star3" name="rating" value="3" onclick="submitRating(3)"><label for="star3" title="Good">★</label>
                <input type="radio" id="star2" name="rating" value="2" onclick="submitRating(2)"><label for="star2" title="Needs Practice">★</label>
                <input type="radio" id="star1" name="rating" value="1" onclick="submitRating(1)"><label for="star1" title="Burnt it">★</label>
            </div>
            <span class="clear-rating-btn" onclick="clearRating()">Clear Saved Rating</span>
        </div>
    </div>

    <script>
        function toggleTheme() {
            const html = document.documentElement;
            if (html.getAttribute('data-theme') === 'dark') {
                html.removeAttribute('data-theme');
                localStorage.setItem('branchOutTheme', 'light');
                document.getElementById('themeToggleBtn').innerText = '🌙';
                document.querySelector('meta[name="theme-color"]').setAttribute('content', '#fdf8e4');
            } else {
                html.setAttribute('data-theme', 'dark');
                localStorage.setItem('branchOutTheme', 'dark');
                document.getElementById('themeToggleBtn').innerText = '☀️';
                document.querySelector('meta[name="theme-color"]').setAttribute('content', '#111111');
            }
        }
        window.addEventListener('DOMContentLoaded', () => {
            if (localStorage.getItem('branchOutTheme') === 'dark') document.getElementById('themeToggleBtn').innerText = '☀️';
        });

        // --- ALL 7 JOURNEYS DATA ---
        const projectLibrary = {
            kitchen: {
                colors: { left: '#ff7043', right: null }, 
                name: "🔪 Kitchen RPG",
                leftTree: {
                    tier1: {
                        layout: 'parallel',
                        paths: [
                            {
                                theme: 'theme-easy',
                                nodes: [
                                    { id: "c_tool", passReq: 7, title: "Equipment", skills: [{ name: "Cast Iron", desc: "Seasoning & Care"}, { name: "Sharpening", desc: "Whetstone usage" }] },
                                    { id: "c_boss0", passReq: 4, title: "BOSS: Station Setup", skills: [{name:"Ready for Service", desc:"Tools sharp, pans seasoned"}], isBoss: true }
                                ],
                                branches: [
                                    { nodes: [{ id: "c_blade", passReq: 7, title: "Blade Mastery", skills: [{name:"Mandoline", desc:"Safe uniform slicing"}, {name:"Honing Steel", desc:"Edge alignment"}] }] },
                                    { nodes: [{ id: "c_machine", passReq: 7, title: "Machine Mastery", skills: [{name:"Food Processor", desc:"Emulsifying blades"}, {name:"Stand Mixer", desc:"Dough hooks & limits"}] }] }
                                ]
                            },
                            {
                                theme: 'theme-easy',
                                nodes: [
                                    { id: "c_prep", passReq: 7, title: "Prep Cook", skills: [{ name: "Knife Skills", desc: "Dice onion, mince garlic"}, { name: "Mise en Place", desc: "Organize ingredients" }] },
                                    { id: "c_boss1", passReq: 4, title: "BOSS: Perfect Salad", skills: [{name:"Vinaigrette & Cuts", desc:"Uniform veg with basic dressing"}], isBoss: true }
                                ],
